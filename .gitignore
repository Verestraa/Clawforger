# ─── Secrets — NEVER COMMIT ───────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
keystore/
wallet.json
secrets/
**/secrets.json

# ─── Dependencies ────────────────────────────────────────────
node_modules/
.pnpm-store/
.bun/
.turbo/

# ─── Build output ────────────────────────────────────────────
dist/
build/
out/                 # Foundry output
cache/               # Foundry cache
.next/
.vite/
.vercel/
.svelte-kit/
*.tsbuildinfo

# ─── Coverage / test artifacts ───────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ─── OS / IDE ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# ─── Foundry-specific ────────────────────────────────────────
broadcast/           # Foundry broadcast logs may contain sensitive info
broadcast/*/*/run-latest.json
!broadcast/*/run-latest.json   # keep latest if you want, but generally exclude

# ─── Local-only addresses + state ────────────────────────────
addresses.local.json
.deployments/

# ─── Bun lockfile is committed; package-lock not used ────────
package-lock.json
yarn.lock
