{
  "name": "@clawforger/core",
  "version": "0.0.1",
  "description": "Clawforger agent runtime — types, Agent class, hooks, chain configs",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./chains": {
      "types": "./src/chains.ts",
      "import": "./src/chains.ts"
    },
    "./personas": {
      "types": "./src/personas.ts",
      "import": "./src/personas.ts"
    },
    "./agent-wallet": {
      "types": "./src/agent-wallet.ts",
      "import": "./src/agent-wallet.ts"
    },
    "./abis/*": "./src/abis/*"
  },
  "scripts": {
    "build": "tsup src/index.ts src/types.ts src/chains.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/types.ts src/chains.ts --format esm --dts --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@0gfoundation/0g-compute-ts-sdk": "^0.8.0",
    "ethers": "^6.16.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
