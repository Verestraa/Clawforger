{
  "name": "@clawforger/x402-facilitator",
  "version": "0.0.1",
  "description": "Self-hosted x402 facilitator on 0G — verifies signed payment authorizations against on-chain mUSDC allowance",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": { "types": "./src/index.ts", "import": "./src/index.ts" }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean",
    "start": "bun run src/server.ts",
    "dev": "bun run --watch src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clawforger/core": "workspace:*",
    "hono": "^4.6.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
