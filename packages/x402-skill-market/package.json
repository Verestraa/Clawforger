{
  "name": "@clawforger/x402-skill-market",
  "version": "0.0.1",
  "description": "HTTP 402 paywalled skill marketplace — discovery, paywall, settlement via KeeperHub",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./client": { "import": "./dist/client.js", "types": "./dist/client.d.ts" }
  },
  "scripts": {
    "build": "tsup src/index.ts src/client.ts src/server.ts --format esm --dts --clean",
    "start": "bun run src/server.ts",
    "dev": "bun run --watch src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clawforger/core": "workspace:*",
    "@clawforger/keeperhub-execute": "workspace:*",
    "hono": "^4.6.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
