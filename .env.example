# Clawforger environment — copy to .env and fill in
# .env is gitignored; this file is committed as a template.

# ────────────────────────────────────────────────────────────────
# Wallet — for contract deploys + agent operations on 0G Galileo
# Generate: `cast wallet new` (Foundry) — fund the resulting address via 0G faucet
# ────────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=

# ────────────────────────────────────────────────────────────────
# 0G — chain, storage, compute
# ────────────────────────────────────────────────────────────────
# Contracts run on 0G Galileo testnet (16602). See MAINNET.md for why
# we don't deploy contracts to Aristotle mainnet (16661): no canonical
# USD stablecoin on mainnet yet, so deploying there gains nothing.
ZG_GALILEO_RPC=https://evmrpc-testnet.0g.ai
ZG_GALILEO_CHAIN_ID=16602
ZG_GALILEO_EXPLORER=https://chainscan-galileo.0g.ai

# Aristotle mainnet — used by Compute (NOT contracts). Mainnet has
# DeepSeek v3 / GLM-5 / gpt-5.4-mini; testnet only has qwen-2.5-7b
# which hallucinates badly. Wallet on this RPC needs real 0G tokens
# (≥3 to create the broker ledger, ≥1 per provider sub-account).
ZG_MAINNET_RPC=https://evmrpc.0g.ai
ZG_MAINNET_CHAIN_ID=16661

ZG_STORAGE_INDEXER_RPC=
ZG_STORAGE_NODE_RPC=

# Which RPC the Compute broker SDK connects to. Defaults to Aristotle
# mainnet for production-grade models. Set to ZG_GALILEO_RPC to fall
# back to testnet broker (qwen only).
ZG_COMPUTE_RPC=https://evmrpc.0g.ai
ZG_COMPUTE_BROKER_URL=
# Model hint — substring matched against discovered services. Options:
#   deepseek (default, strong tool-calling, cheapest agent-grade)
#   glm      (zai-org/GLM-5-FP8 or GLM-5.1-FP8)
#   gpt-oss  (openai/gpt-5.4-mini, premium tool format)
#   qwen     (qwen3.6-plus or qwen3-vl-30b)
ZG_COMPUTE_MODEL=deepseek

# ────────────────────────────────────────────────────────────────
# KeeperHub — get from https://app.keeperhub.com → API keys
# ────────────────────────────────────────────────────────────────
KEEPERHUB_API_KEY=
KEEPERHUB_MCP_URL=https://app.keeperhub.com/mcp
KEEPERHUB_PROJECT_ID=

# ────────────────────────────────────────────────────────────────
# x402 — self-hosted facilitator on 0G (we run our own)
# Use the same wallet as DEPLOYER, or a separate one if you prefer
# ────────────────────────────────────────────────────────────────
X402_FACILITATOR_URL=http://localhost:3701
X402_FACILITATOR_PRIVATE_KEY=

# ────────────────────────────────────────────────────────────────
# Studio frontend (Vite-prefixed envs leak into the browser bundle —
# never put secrets here)
# ────────────────────────────────────────────────────────────────
VITE_X402_MARKET_URL=http://localhost:3700
VITE_DEFAULT_CHAIN=0g-galileo-testnet
VITE_WALLETCONNECT_PROJECT_ID=

# ────────────────────────────────────────────────────────────────
# Contract addresses — populated by Day-1 deploy (mirror addresses.json)
# ────────────────────────────────────────────────────────────────
CLAWFORGER_INFT_ADDRESS=
SKILL_REGISTRY_ADDRESS=
ROYALTY_VAULT_TEMPLATE=
MUSDC_ADDRESS=

# ────────────────────────────────────────────────────────────────
# Per-agent deterministic wallet derivation
# ────────────────────────────────────────────────────────────────
# 32-byte hex seed (66 chars including 0x). Each iNFT tokenId derives a
# unique signing wallet via keccak256(seed || tokenId). Same seed → same
# addresses every server boot. Regenerating this seed RE-ASSIGNS every
# agent's wallet, stranding funds at the old addresses. KEEP SECRET.
# Generate via:
#   bun -e 'const a=new Uint8Array(32); crypto.getRandomValues(a); console.log("0x"+Array.from(a).map(b=>b.toString(16).padStart(2,"0")).join(""))'
AGENT_WALLET_SEED=
